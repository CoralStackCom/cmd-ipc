{
  "name": "@examples/electron-main",
  "productName": "Electron Main Process",
  "version": "1.0.0",
  "description": "An example Electron.js app that uses an extensible command IPC framework to communicate between processes.",
  "license": "MIT",
  "main": ".webpack/main",
  "scripts": {
    "start": "electron-forge start",
    "package": "electron-forge package",
    "make": "electron-forge make",
    "publish": "electron-forge publish",
    "typecheck": "tsc --noEmit",
    "test": "vitest --run"
  },
  "installConfig": {
    "hoistingLimits": "workspaces"
  },
  "dependencies": {
    "@coralstack/cmd-ipc": "workspace:*",
    "@examples/electron-core": "workspace:*",
    "electron-log": "^5.4.3",
    "electron-squirrel-startup": "^1.0.1",
    "update-electron-app": "3.1.1"
  },
  "devDependencies": {
    "@electron-forge/cli": "^7.7.0",
    "@electron-forge/maker-deb": "^7.7.0",
    "@electron-forge/maker-rpm": "^7.7.0",
    "@electron-forge/maker-squirrel": "^7.7.0",
    "@electron-forge/maker-zip": "^7.7.0",
    "@electron-forge/plugin-auto-unpack-natives": "^7.7.0",
    "@electron-forge/plugin-fuses": "^7.7.0",
    "@electron-forge/plugin-webpack": "^7.7.0",
    "@electron/fuses": "^1.8.0",
    "@pmmmwh/react-refresh-webpack-plugin": "^0.5.15",
    "@types/node": "^22.13.5",
    "@vercel/webpack-asset-relocator-loader": "1.7.3",
    "css-loader": "^7.1.2",
    "electron": "^35.1.3",
    "fork-ts-checker-webpack-plugin": "^9.0.2",
    "node-loader": "^2.1.0",
    "react-refresh": "^0.17.0",
    "style-loader": "^4.0.0",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "typescript": "*",
    "vitest": "*",
    "webpack": "*"
  }
}
