{
  "description": "Executing an unknown command returns a structured not_found response, not an exception.",
  "setup": {
    "registry": { "id": "main" },
    "peers": [{ "channelId": "worker-1" }]
  },
  "steps": [
    {
      "direction": "inbound",
      "from": "worker-1",
      "message": {
        "id": "11111111-1111-4111-8111-111111111111",
        "type": "execute.command.request",
        "commandId": "does.not.exist",
        "request": {}
      }
    },
    {
      "direction": "outbound",
      "to": "worker-1",
      "expected": {
        "id": { "$match": "uuid" },
        "type": "execute.command.response",
        "thid": "11111111-1111-4111-8111-111111111111",
        "response": {
          "ok": false,
          "error": { "code": "not_found", "message": { "$match": "any-string" } }
        }
      }
    }
  ]
}
