{
  "description": "Receiving two event messages with the same 'id' delivers to local listeners exactly once (dedup). The first delivery is still forwarded to other connected channels as a mesh broadcast; the duplicate is dropped entirely.",
  "setup": {
    "registry": { "id": "main", "localEventListeners": ["user.updated"] },
    "peers": [{ "channelId": "worker-1" }, { "channelId": "worker-2" }]
  },
  "steps": [
    {
      "direction": "inbound",
      "from": "worker-1",
      "message": { "id": "44444444-4444-4444-8444-444444444444", "type": "event", "eventId": "user.updated", "payload": { "userId": 1 } }
    },
    {
      "description": "First event is forwarded to the other channel as mesh broadcast.",
      "direction": "outbound",
      "to": "worker-2",
      "expected": { "type": "event", "eventId": "user.updated", "payload": { "userId": 1 } }
    },
    {
      "direction": "inbound",
      "from": "worker-2",
      "message": { "id": "44444444-4444-4444-8444-444444444444", "type": "event", "eventId": "user.updated", "payload": { "userId": 1 } }
    },
    {
      "description": "Duplicate is dropped — it is NOT re-broadcast back to worker-1.",
      "direction": "assert-no-outbound",
      "to": "worker-1"
    },
    {
      "direction": "assert-local-listener",
      "eventId": "user.updated",
      "invocations": 1
    }
  ]
}
