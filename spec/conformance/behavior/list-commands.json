{
  "description": "list.commands.request returns all locally-known public commands via thid correlation.",
  "setup": {
    "registry": {
      "id": "main",
      "localCommands": [
        { "id": "math.add" },
        { "id": "math.sub" },
        { "id": "_secret.ping" }
      ]
    },
    "peers": [{ "channelId": "worker-1" }]
  },
  "steps": [
    {
      "direction": "inbound",
      "from": "worker-1",
      "message": {
        "id": "11111111-1111-4111-8111-111111111111",
        "type": "list.commands.request"
      }
    },
    {
      "direction": "outbound",
      "to": "worker-1",
      "expected": {
        "type": "list.commands.response",
        "thid": "11111111-1111-4111-8111-111111111111",
        "commands": {
          "$unordered": [{ "id": "math.add" }, { "id": "math.sub" }]
        }
      }
    }
  ]
}
